# Clé secrète qui signe les connexions — mettez une longue chaîne aléatoire (obligatoire en production)
JWT_SECRET=remplacez-par-une-longue-chaine-aleatoire

# Base de données PostgreSQL (Neon, Supabase, etc.). Laissez vide pour utiliser un fichier JSON local.
# Exemple Neon : postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Port (Render le fournit automatiquement ; en local, 4000 par défaut)
PORT=4000
